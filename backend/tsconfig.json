{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    
    /* Project Structure */
    "rootDir": "./src",
    "outDir": "./dist",
    "baseUrl": "./src",
    
    /* Module Resolution */
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    
    /* Strictness */
    "strict": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": true,
    
    /* Quality of Life */
    "skipLibCheck": true,
    "sourceMap": true,
    
    /* Output */
    "declaration": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}